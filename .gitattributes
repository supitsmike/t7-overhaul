# Default: detect text vs binary, normalise to LF on commit
* text=auto eol=lf

# Files that must be CRLF for Windows tooling
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.sln       text eol=crlf
*.slnx      text eol=crlf
*.vcxproj   text eol=crlf
*.props     text eol=crlf
*.targets   text eol=crlf

# Sources
*.c     text eol=lf
*.cpp   text eol=lf
*.h     text eol=lf
*.hpp   text eol=lf
*.lua   text eol=lf
*.md    text eol=lf

# Binary
*.exe   binary
*.dll   binary
*.lib   binary
*.obj   binary
*.pdb   binary
*.ico   binary
*.png   binary
*.jpg   binary
