root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{c,cpp,h,hpp}]
indent_size = 4

[*.lua]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{bat,cmd,sln,slnx,vcxproj,props,targets,manifest,rc}]
end_of_line = crlf
